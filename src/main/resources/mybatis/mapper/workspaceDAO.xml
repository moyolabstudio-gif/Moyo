<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.springboot.project.dao.IworkspaceDAO">

	<insert id="insertWorkspace" parameterType="com.springboot.project.dto.workspaceDTO">
	    <selectKey keyProperty="wsId" resultType="long" order="BEFORE">
	        SELECT SEQ_WS_ID.NEXTVAL FROM DUAL
	    </selectKey>
	
	    INSERT INTO WORKSPACES (
	        WS_ID, 
	        WS_NAME, 
	        INVITE_CODE, 
	        OWNER_ID
	    ) VALUES (
	        #{wsId}, 
	        #{wsName}, 
	        #{inviteCode}, 
	        #{ownerId}
	    )
	</insert>
	
	<select id="selectWorkspaceList" parameterType="long" resultType="com.springboot.project.dto.workspaceDTO">
	    SELECT 
	        WS_ID, 
	        WS_NAME, 
	        INVITE_CODE, 
	        OWNER_ID 
	    FROM WORKSPACES 
	    WHERE OWNER_ID = #{userId}
	    ORDER BY WS_ID DESC
	</select>
	
	<select id="selectWorkspaceDetail" parameterType="long" resultType="com.springboot.project.dto.workspaceDTO">
	    SELECT 
	        WS_ID, 
	        WS_NAME, 
	        INVITE_CODE, 
	        OWNER_ID 
	    FROM WORKSPACES 
	    WHERE WS_ID = #{wsId}
	</select>

</mapper>